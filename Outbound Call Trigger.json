      "parameters": {
        "jsCode": "const events = $input.item.json.body;\n\nconst importantProperties = [\n  'phone', \n  'firstname', \n  'lastname', \n  'company',\n  'website', \n  'what_services_would_you_like_help_with_' \n];\n\n// 1. CHECK RELEVANCE\nconst isRelevant = events.some(event => {\n  if (event.subscriptionType === 'contact.creation') return true;\n  if (event.subscriptionType === 'contact.propertyChange' && \n      event.propertyName === 'ai_call_trigger' && \n      event.propertyValue === 'Yes') return true;\n  if ((event.subscriptionType === 'contact.propertyChange' || event.subscriptionType === 'object.propertyChange') && \n      importantProperties.includes(event.propertyName)) return true;\n\n  return false;\n});\n\nif (!isRelevant) return [];\n\nreturn {\n  json: {\n    objectId: events[0].objectId,\n    ...$input.item.json\n  }\n};"
      },
