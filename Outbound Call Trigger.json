    {
      "parameters": {
        "jsCode": "const currentExecutionId = $execution.id;\nconst contactProps = $node[\"Get Contact Details\"].json.properties;\nconst lastMeetingStr = contactProps.hs_last_booked_meeting_date ? contactProps.hs_last_booked_meeting_date.value : null;\nconst latestIdOnRecord = contactProps.latest_n8n_execution_id ? contactProps.latest_n8n_execution_id.value : null;\n\nlet shouldCall = true;\n\nif (lastMeetingStr) {\n    const formTime = $node[\"Webhook: HubSpot Lead\"].json.body[0].occurredAt;\n    const lastMeetingTime = parseInt(lastMeetingStr, 10);\n    if (lastMeetingTime > formTime) {\n        shouldCall = false;\n    }\n}\n\nif (latestIdOnRecord && latestIdOnRecord !== currentExecutionId) {\n    shouldCall = false;\n}\n\nreturn {\n    json: {\n        ...$input.item.json,\n        shouldCall: shouldCall\n    }\n};"
      },
