    {
      "parameters": {
        "jsCode": "const properties = $input.first().json.properties;\nconst phoneObj = properties && properties.phone;\nconst phone = phoneObj ? phoneObj.value : null;\n\nif (!phone) {\n  return {\n    json: {\n      ...$input.item.json,\n      hasPhone: false,\n      formattedPhone: null\n    }\n  };\n}\n\nlet cleaned = phone.toString().replace(/\\D/g, '');\nlet finalPhone = cleaned;\n\nif (phone.toString().startsWith('+')) {\n    finalPhone = phone.toString();\n} \nelse if (cleaned.length === 10) {\n  finalPhone = '+1' + cleaned;\n} \nelse if (cleaned.length === 11 && cleaned.startsWith('1')) {\n  finalPhone = '+' + cleaned;\n}\nelse if (cleaned.length > 10) {\n    finalPhone = '+' + cleaned;\n}\n\nreturn {\n  json: {\n    ...$input.item.json,\n    hasPhone: true,\n    formattedPhone: finalPhone\n  }\n};"
      },
      "id": "bddb2b8a-8656-4f32-93b4-e29262bcc8b7",
